{
  "kind": "collectionType",
  "collectionName": "students",
  "info": {
    "singularName": "student",
    "pluralName": "students",
    "displayName": "Student"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true
    },
    "Age": {
      "type": "integer",
      "required": true,
      "min": 7,
      "max": 20
    },
    "Gender": {
      "type": "boolean"
    },
    "ClassNo": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::class.class",
      "inversedBy": "ClassNo"
    },
    "Birthdate": {
      "type": "date"
    }
  }
}
